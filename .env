# Copier ce fichier en .env.local et adapter les valeurs — ne jamais committer .env.local

APP_ENV=dev
APP_SECRET=change_moi_en_local
DEFAULT_URI=http://localhost

# Adapter host/port/nom de base/version selon ton environnement local (voir README)
DATABASE_URL="mysql://folkmanager:change_moi@127.0.0.1:3306/folkmanager?serverVersion=10.11-MariaDB&charset=utf8mb4"

# Clé utilisée pour chiffrer les access tokens des réseaux sociaux (ReseauSocialCompte::accessTokenChiffre)
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
SOCIAL_TOKEN_ENCRYPTION_KEY=change_moi
